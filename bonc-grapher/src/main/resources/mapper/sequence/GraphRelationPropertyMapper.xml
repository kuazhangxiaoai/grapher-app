    <delete id="batchDeleteByRelationIds">
        DELETE FROM graph_relation_property WHERE relation_id IN
        <foreach collection="relationIds" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

</mapper>